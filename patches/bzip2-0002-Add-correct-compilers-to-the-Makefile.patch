From 38af60f33ca01c570a70eedcaf4cd55795fb672b Mon Sep 17 00:00:00 2001
From: Zebreus <zebreus@zebre.us>
Date: Wed, 1 Oct 2025 10:38:17 +0200
Subject: [PATCH] Add correct compilers to the Makefile

---
 Makefile           | 6 +++---
 Makefile-libbz2_so | 2 +-
 2 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/Makefile b/Makefile
index f8a1772..be2a28d 100644
--- a/Makefile
+++ b/Makefile
@@ -15,9 +15,9 @@
 SHELL=/bin/sh
 
 # To assist in cross-compiling
-CC=gcc
-AR=ar
-RANLIB=ranlib
+CC=wasixcc
+AR=wasixar
+RANLIB=wasixranlib
 LDFLAGS=
 
 BIGFILES=-D_FILE_OFFSET_BITS=64
diff --git a/Makefile-libbz2_so b/Makefile-libbz2_so
index fb0f230..a753427 100644
--- a/Makefile-libbz2_so
+++ b/Makefile-libbz2_so
@@ -22,7 +22,7 @@
 
 
 SHELL=/bin/sh
-CC=gcc
+CC=wasixcc
 BIGFILES=-D_FILE_OFFSET_BITS=64
 CFLAGS=-fpic -fPIC -Wall -Winline -O2 -g $(BIGFILES)
 
-- 
2.48.1

