From 830b5f075793f32f6de1ddd9602ea3564fd86391 Mon Sep 17 00:00:00 2001
From: Zebreus <zebreus@zebre.us>
Date: Tue, 6 Jan 2026 21:14:04 +0100
Subject: [PATCH] Allow setting the compiler via the CC var

---
 src/rust/cryptography-cffi/build.rs | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/rust/cryptography-cffi/build.rs b/src/rust/cryptography-cffi/build.rs
index d0d6443d8..d17caa469 100644
--- a/src/rust/cryptography-cffi/build.rs
+++ b/src/rust/cryptography-cffi/build.rs
@@ -61,7 +61,7 @@ fn main() {
 
     let mut build = cc::Build::new();
     if std::env::var("CARGO_CFG_TARGET_VENDOR").unwrap() == "wasmer" {
-        build.compiler("wasixcc");
+        build.compiler(&std::env::var("CC").unwrap_or("wasixcc".to_string()));
     }
     build
         .file(openssl_c)
-- 
2.51.0

