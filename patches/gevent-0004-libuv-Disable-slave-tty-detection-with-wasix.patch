From 3b50b08e4fc4849a082e5bc34e67f662e683e948 Mon Sep 17 00:00:00 2001
From: Arshia Ghafoori <arshia001@live.com>
Date: Thu, 18 Dec 2025 11:00:18 +0100
Subject: [PATCH 04/12] libuv: Disable slave tty detection with wasix

---
 deps/libuv/src/unix/tty.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/deps/libuv/src/unix/tty.c b/deps/libuv/src/unix/tty.c
index b8610720..64c6c22d 100644
--- a/deps/libuv/src/unix/tty.c
+++ b/deps/libuv/src/unix/tty.c
@@ -125,6 +125,9 @@ static int uv__tty_is_slave(const int fd) {
     abort();
 
   result = (pts == major(sb.st_rdev));
+#elif defined(__wasi__)
+  /* No way to determine if the fd is a slave tty on this platform. */
+  result = 0;
 #else
   /* Fallback to ptsname
    */
