From b41637fbf4b252d2ce1434a493e22ea3afb731a4 Mon Sep 17 00:00:00 2001
From: Zebreus <zebreus@zebre.us>
Date: Wed, 1 Oct 2025 10:32:21 +0200
Subject: [PATCH] Allow writing binary data to a terminal

---
 bzip2.c | 74 ++++++++++++++++++++++++++++-----------------------------
 1 file changed, 37 insertions(+), 37 deletions(-)

diff --git a/bzip2.c b/bzip2.c
index d95d280..a1f9d98 100644
--- a/bzip2.c
+++ b/bzip2.c
@@ -1227,30 +1227,30 @@ void compress ( Char *name )
       case SM_I2O:
          inStr = stdin;
          outStr = stdout;
-         if ( isatty ( fileno ( stdout ) ) ) {
-            fprintf ( stderr,
-                      "%s: I won't write compressed data to a terminal.\n",
-                      progName );
-            fprintf ( stderr, "%s: For help, type: `%s --help'.\n",
-                              progName, progName );
-            setExit(1);
-            return;
-         };
+         // if ( isatty ( fileno ( stdout ) ) ) {
+         //    fprintf ( stderr,
+         //              "%s: I won't write compressed data to a terminal.\n",
+         //              progName );
+         //    fprintf ( stderr, "%s: For help, type: `%s --help'.\n",
+         //                      progName, progName );
+         //    setExit(1);
+         //    return;
+         // };
          break;
 
       case SM_F2O:
          inStr = fopen ( inName, "rb" );
          outStr = stdout;
-         if ( isatty ( fileno ( stdout ) ) ) {
-            fprintf ( stderr,
-                      "%s: I won't write compressed data to a terminal.\n",
-                      progName );
-            fprintf ( stderr, "%s: For help, type: `%s --help'.\n",
-                              progName, progName );
-            if ( inStr != NULL ) fclose ( inStr );
-            setExit(1);
-            return;
-         };
+         // if ( isatty ( fileno ( stdout ) ) ) {
+         //    fprintf ( stderr,
+         //              "%s: I won't write compressed data to a terminal.\n",
+         //              progName );
+         //    fprintf ( stderr, "%s: For help, type: `%s --help'.\n",
+         //                      progName, progName );
+         //    if ( inStr != NULL ) fclose ( inStr );
+         //    setExit(1);
+         //    return;
+         // };
          if ( inStr == NULL ) {
             fprintf ( stderr, "%s: Can't open input file %s: %s.\n",
                       progName, inName, strerror(errno) );
@@ -1413,15 +1413,15 @@ void uncompress ( Char *name )
       case SM_I2O:
          inStr = stdin;
          outStr = stdout;
-         if ( isatty ( fileno ( stdin ) ) ) {
-            fprintf ( stderr,
-                      "%s: I won't read compressed data from a terminal.\n",
-                      progName );
-            fprintf ( stderr, "%s: For help, type: `%s --help'.\n",
-                              progName, progName );
-            setExit(1);
-            return;
-         };
+         // if ( isatty ( fileno ( stdin ) ) ) {
+         //    fprintf ( stderr,
+         //              "%s: I won't read compressed data from a terminal.\n",
+         //              progName );
+         //    fprintf ( stderr, "%s: For help, type: `%s --help'.\n",
+         //                      progName, progName );
+         //    setExit(1);
+         //    return;
+         // };
          break;
 
       case SM_F2O:
@@ -1554,15 +1554,15 @@ void testf ( Char *name )
    switch ( srcMode ) {
 
       case SM_I2O:
-         if ( isatty ( fileno ( stdin ) ) ) {
-            fprintf ( stderr,
-                      "%s: I won't read compressed data from a terminal.\n",
-                      progName );
-            fprintf ( stderr, "%s: For help, type: `%s --help'.\n",
-                              progName, progName );
-            setExit(1);
-            return;
-         };
+         // if ( isatty ( fileno ( stdin ) ) ) {
+         //    fprintf ( stderr,
+         //              "%s: I won't read compressed data from a terminal.\n",
+         //              progName );
+         //    fprintf ( stderr, "%s: For help, type: `%s --help'.\n",
+         //                      progName, progName );
+         //    setExit(1);
+         //    return;
+         // };
          inStr = stdin;
          break;
 
