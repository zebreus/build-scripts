From 0dd9f93c7370c70232776fb64b58c1052a68172f Mon Sep 17 00:00:00 2001
From: Arshia Ghafoori <arshia001@live.com>
Date: Thu, 18 Dec 2025 11:24:59 +0100
Subject: [PATCH 12/12] libuv: Fix WASIX thread spawning erroring out with a
 signature mismatch by adding a trampoline

---
 deps/libuv/src/unix/thread.c | 29 ++++++++++++++++++++++-------
 1 file changed, 22 insertions(+), 7 deletions(-)

diff --git a/deps/libuv/src/unix/thread.c b/deps/libuv/src/unix/thread.c
index 8f050fb0..cd799e3b 100644
--- a/deps/libuv/src/unix/thread.c
+++ b/deps/libuv/src/unix/thread.c
@@ -58,6 +58,11 @@
 #undef NANOSEC
 #define NANOSEC ((uint64_t) 1e9)
 
+typedef struct {
+  void (*entry)(void* arg);
+  void* arg;
+} uv__thread_start_args_t;
+
 /* Musl's PTHREAD_STACK_MIN is 2 KB on all architectures, which is
  * too small to safely receive signals on.
  *
@@ -122,6 +127,15 @@ size_t uv__thread_stack_size(void) {
   return uv__default_stack_size();
 }
 
+static void* uv__thread_start_trampoline(void* arg) {
+  uv__thread_start_args_t* args = (uv__thread_start_args_t*) arg;
+
+  args->entry(args->arg);
+
+  uv__free(args);
+
+  return NULL;
+}
 
 int uv_thread_create(uv_thread_t *tid, void (*entry)(void *arg), void *arg) {
   uv_thread_options_t params;
@@ -145,12 +159,14 @@ int uv_thread_create_ex(uv_thread_t* tid,
   size_t pagesize;
   size_t stack_size;
   size_t min_stack_size;
+  uv__thread_start_args_t* start_args;
 
-  /* Used to squelch a -Wcast-function-type warning. */
-  union {
-    void (*in)(void*);
-    void* (*out)(void*);
-  } f;
+  start_args = uv__malloc(sizeof(*start_args));
+  if (start_args == NULL) {
+    abort();
+  }
+  start_args->entry = entry;
+  start_args->arg = arg;
 
   stack_size =
       params->flags & UV_THREAD_HAS_STACK_SIZE ? params->stack_size : 0;
@@ -177,8 +193,7 @@ int uv_thread_create_ex(uv_thread_t* tid,
       abort();
   }
 
-  f.in = entry;
-  err = pthread_create(tid, attr, f.out, arg);
+  err = pthread_create(tid, attr, uv__thread_start_trampoline, start_args);
 
   if (attr != NULL)
     pthread_attr_destroy(attr);
-- 
